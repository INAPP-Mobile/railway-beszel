# =============================================================================
# Beszel — Environment Variables
# https://beszel.dev/guide/configuration/environment-variables
# =============================================================================

# --- Port ---
# Beszel listens on port 8090 internally. Railway needs PORT to match.
PORT=8090

# --- URL Configuration ---
# Public URL of the hub. Used for links in emails and notifications.
# Set this to your Railway deployment URL.
# APP_URL=https://beszel-production.up.railway.app

# --- Authentication ---
# Email of a user to auto-authenticate (skip login page).
# AUTO_LOGIN=admin@example.com

# Disable password auth (use OAuth/OIDC only).
# DISABLE_PASSWORD_AUTH=true

# --- Updates ---
# CHECK_UPDATES=false

# --- Container Details ---
# Allow viewing container details (inspect, logs) in the web UI.
# CONTAINER_DETAILS=true

# --- Alert Webhooks ---
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# GOTIFY_URL=https://gotify.example.com
# GOTIFY_TOKEN=your-gotify-token

# --- Backup (S3-compatible) ---
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_REGION=us-east-1
# S3_BUCKET=beszel-backups
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key

# --- OAuth / OIDC ---
# OAUTH_PROVIDER=github
# OAUTH_CLIENT_ID=your-client-id
# OAUTH_CLIENT_SECRET=your-client-secret
# OAUTH_REDIRECT_URL=https://beszel-production.up.railway.app/oauth/redirect
